{
  "name": "hyp-sprites-img",
  "version": "0.1.3",
  "author": {
    "name": "黄裕平",
    "email": "83470005@qq.com",
    "url": "https://github.com/Rupiong"
  },
  "description": "基于 Vue 3 + Vite 的雪碧图工具：构建期生成每帧坐标，支持远程图、网格与透明区检测，告别手写 background-position。",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./virtual": {
      "types": "./dist/virtual.d.ts",
      "default": "./dist/virtual.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --emitDeclarationOnly && cp src/virtual.d.ts dist/virtual.d.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "vue",
    "vue3",
    "sprite",
    "spritesheet",
    "css-sprite"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0",
    "vue": "^3.3.0"
  },
  "dependencies": {
    "image-size": "^1.1.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "rollup": "^4.28.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
